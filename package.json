{
  "name": "umyz-blog",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npm run gen:articles && npm run gen:slugmap && next dev",
    "build": "npm run gen:articles && npm run gen:slugmap && npm run gen:sitemap && npm run gen:rss && next build",
    "gen:articles": "node scripts/generate-articles.js",
    "gen:slugmap": "node scripts/generate-slug-map.js",
    "gen:sitemap": "node scripts/generate-sitemap.mjs",
    "gen:rss": "node scripts/generate-rss.mjs",
    "start": "next start",
    "lint": "eslint src/",
    "docker:dev": "docker compose up --build",
    "docker:prod": "docker compose --profile production up --build"
  },
  "browserslist": {
    "production": [
      ">0.5%",
      "not dead",
      "not op_mini all",
      "defaults, not ie <= 11"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "dependencies": {
    "@fortawesome/fontawesome-svg-core": "^7.1.0",
    "@fortawesome/free-brands-svg-icons": "^7.1.0",
    "@fortawesome/free-solid-svg-icons": "^7.1.0",
    "@fortawesome/react-fontawesome": "^3.2.0",
    "@headlessui/react": "^1.7.13",
    "@mdx-js/loader": "^2.1.5",
    "@mdx-js/react": "^2.1.5",
    "@next/mdx": "^15.5.12",
    "@sindresorhus/slugify": "^2.1.1",
    "@tailwindcss/typography": "^0.5.8",
    "@vercel/analytics": "^1.6.1",
    "@vercel/speed-insights": "^1.3.1",
    "acorn": "^8.8.2",
    "algoliasearch": "^4.17.0",
    "allof-merge": "^0.6.6",
    "autoprefixer": "^10.4.7",
    "clsx": "^1.2.0",
    "dompurify": "^3.3.1",
    "focus-visible": "^5.2.0",
    "framer-motion": "10.12.9",
    "github-slugger": "^2.0.0",
    "js-yaml": "^4.1.0",
    "lucide-react": "^0.562.0",
    "mdast-util-to-string": "^3.2.0",
    "mdx-annotations": "^0.1.1",
    "next": "^15.5.12",
    "next-mdx-remote": "^6.0.0",
    "openapi-types": "^12.1.0",
    "postcss-focus-visible": "^8.0.2",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-toastify": "^9.1.3",
    "recma-nextjs-static-props": "^1.0.0",
    "rehype-mdx-title": "^2.0.0",
    "rehype-slug": "^5.1.0",
    "remark-gfm": "^4.0.1",
    "shiki": "^0.14.2",
    "tailwindcss": "^3.3.0",
    "unist-util-visit": "^4.1.2",
    "zustand": "^4.3.8"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.4",
    "@types/dompurify": "^3.0.5",
    "eslint": "^9.39.3",
    "eslint-config-next": "^15.5.12",
    "prettier": "^3.2.5",
    "prettier-plugin-tailwindcss": "^0.5.11"
  }
}
